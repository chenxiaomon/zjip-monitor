page {
  background: #f5f5f5;
  font-family: -apple-system, "PingFang SC", sans-serif;
  font-size: 28rpx;
  color: #333;
}

/* Status pill colors */
.pill-1  { background: #E6F1FB; color: #0C447C; }
.pill-2  { background: #FAEEDA; color: #854F0B; }
.pill-3  { background: #EEEDFE; color: #3C3489; }
.pill-5  { background: #F1EFE8; color: #444441; }
.pill-6  { background: #FCEBEB; color: #791F1F; }
.pill-7  { background: #EAF3DE; color: #27500A; }
.pill-11 { background: #F1EFE8; color: #444441; }

.pill {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  margin: 4rpx 6rpx 4rpx 0;
}
