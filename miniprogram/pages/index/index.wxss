.page {
  padding: 24rpx;
}

.loading {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
}

/* Metric cards */
.metrics {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.metric-card {
  flex: 1;
  background: #f0f0f0;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
}

.metric-card.amber {
  background: #fef7ed;
}

.metric-label {
  font-size: 22rpx;
  color: #888;
  margin-bottom: 8rpx;
}

.metric-label.amber-label {
  color: #92500a;
}

.metric-value {
  font-size: 48rpx;
  font-weight: 500;
  color: #222;
}

.metric-value.amber-value {
  color: #92400e;
}

/* Section title */
.section-title {
  font-size: 24rpx;
  color: #888;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
}

/* Account card */
.account-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 28rpx 28rpx 28rpx;
  margin-bottom: 16rpx;
  position: relative;
}

.dot {
  position: absolute;
  top: 28rpx;
  right: 28rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.dot-green  { background: #22c55e; }
.dot-amber  { background: #f59e0b; }
.dot-red    { background: #ef4444; }

.company-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #222;
  display: block;
  margin-bottom: 16rpx;
  padding-right: 40rpx;
}

.pills {
  margin-bottom: 16rpx;
}

.no-data {
  font-size: 24rpx;
  color: #bbb;
  display: block;
  margin-bottom: 16rpx;
}

.last-check {
  font-size: 22rpx;
  color: #bbb;
  display: block;
}

.arrow {
  position: absolute;
  right: 28rpx;
  bottom: 28rpx;
  color: #ccc;
  font-size: 36rpx;
}

.empty {
  text-align: center;
  color: #bbb;
  padding: 80rpx 0;
}
